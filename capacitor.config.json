{
  "appId": "com.kothasetu.app",
  "appName": "KothaSetu",
  "webDir": "dist",
  "android": {
    "useLegacyBridge": false,
    "adjustModeDecor": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#C8560A",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#C8560A",
      "overlaysWebView": false
    },
    "Geolocation": {
      "permissions": "whenInUse"
    }
  }
}
