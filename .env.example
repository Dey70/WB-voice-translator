# Server-only Azure Translator credentials. Never prefix these with VITE_.
AZURE_TRANSLATOR_KEY=replace-with-your-server-key
AZURE_TRANSLATOR_REGION=replace-with-your-azure-region

# Public HTTPS origin of this Vercel app, required by packaged Android builds.
# Browser deployments should leave this empty and use same-origin /api routes.
VITE_API_BASE_URL=

# Browser key used only to display Google Maps. Restrict it by website/Android app.
VITE_GOOGLE_MAPS_KEY=replace-with-your-browser-maps-key

# Server-only keys used by Vercel Functions. Never prefix these with VITE_.
GOOGLE_ROUTES_API_KEY=replace-with-your-server-routes-key
SERPAPI_KEY=replace-with-your-serpapi-key
